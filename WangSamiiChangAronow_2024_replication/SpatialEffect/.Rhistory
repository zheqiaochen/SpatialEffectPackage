set.seed(123)
kernUp <- function(r,a){exp(-(r/a)^2)}
effectFun <- function(d, sh, sc, a){(dgamma(abs(d), shape=sh, scale=2*sc) - a*dgamma(abs(d), shape=5*sh, scale=sc))}
rug <- rnorm(1000, 0, 2)
f_rug <- approxfun(rug)
# ruggedFun <- function(d, a){exp(-(d/a)^2) + f_rug(d)}
ruggedFun <- function(d, a){exp(-(d/(2*a))^2)*as.numeric(d %% 2 < 1)}
ZSize <- rexp(16)
# generate raster data
# effect is the coefficient before the effect for each obs
generator2 <- function(scale, tr_prob, YZratio, unit_size, inodes = NULL, effect = 3, Y_sd = 0.1, Zjitter = 1, type = "non-monotonic"){
s <- scale
s2 <- scale^2
p <- round(s2*tr_prob)
ras0 <- raster(	nrows=s,
ncols=s,
xmn=0, xmx=s*unit_size,
ymn=0, ymx=s*unit_size,
vals=rnorm(s2, mean=0, sd=Y_sd))
# Dataset with Y0 values and then centroids of the raster cells
Y0 <- getValues(ras0)
Yxy <- coordinates(ras0)
Yindex <- 1:nrow(Yxy)
Ydata <- data.frame(Yindex,cbind(Y0,Yxy))
Zxy <- coordinates(aggregate(ras0, fact=YZratio, fun=mean))
Zxy[,1] <- jitter(Zxy[,1], amount=Zjitter)
Zxy[,2] <- jitter(Zxy[,2], amount=Zjitter)
index <- 1:nrow(Zxy)
Zdata <- as.data.frame(cbind(index, Zxy))
z2 <- dim(Zdata)[1]
for (i in 1:dim(Zdata)[1]){
Ydata[, i+4] <- apply(Ydata[, c(3:4)], 1, function(x) dist(rbind(Zdata[i, c(2:3)], x)))
names(Ydata)[i+4] <- paste0("dZ", i)
}
# Zstart <- rep(0, dim(Zdata)[1])
# Zstart[1:floor(tr_prob*length(Zstart))] <- 1
#
# curZ <- genperms(Zstart, maxiter=1000)
# Zstart <- rbinom(dim(Zdata)[1], 1, tr_prob)
# curZ <- matrix(rbinom(dim(Zdata)[1] * 1000, 1, tr_prob), dim(Zdata)[1], 1000)
curZ <- matrix(NA, dim(Zdata)[1], 1000)
for (c in 1:ncol(curZ)){
tempZ <- rbinom(z2, 1, tr_prob)
while (sum(tempZ) == 0 | sum(tempZ) == z2){
tempZ <- rbinom(z2, 1, tr_prob)
}
curZ[, c] <- tempZ
}
colnames(curZ) <- paste0("curZ",1:ncol(curZ))
Y1s <- matrix(NA, dim(Ydata)[1], ncol(curZ))
colnames(Y1s) <- paste0("Y1_",1:ncol(curZ))
for(k in 1:ncol(curZ)){
if (type == "non-monotonic"){
Y1s[, k] <- Ydata$Y0 + effect*apply(Ydata[,grep("dZ", names(Ydata))],
1,
function(x){sum(effectFun(x, 1, 0.5, 1)*(curZ[,k]))})
}else if (type == "monotonic"){
Y1s[, k] <- Ydata$Y0 + apply(Ydata[,grep("dZ", names(Ydata))],
1,
function(x){sum(kernUp(x, effect)*curZ[,k])})
}else if (type == "none"){
Y1s[, k] <- Ydata$Y0
}else if (type == "rugged"){
Y1s[, k] <- Ydata$Y0 + effect*apply(Ydata[,grep("dZ", names(Ydata))],
1,
function(x){sum(ruggedFun(x, effect)*curZ[,k])})
}
}
for(i in 1:nrow(curZ)){
Ydata[,paste("tau",i,sep="")] <- apply(Y1s[,curZ[i,]==1], 1, mean)-apply(Y1s[,curZ[i,]==0], 1, mean)
}
Ydata <- cbind(Ydata, Y1s)
Zdata <- cbind(Zdata, curZ)
result_list <- list(Ydata, Zdata, ras0)
return(result_list)
}
