s2 <- s^2
tr_prob <- 0.5
YZratio <- 10
unit_size <- 1
radius <- (s * unit_size) * sqrt(2) / 2
inodes <- NULL
effect <- 3
Y_sd <- 1
Zjitter <- 2
# type <- "non-monotonic"
type <- "rugged"
