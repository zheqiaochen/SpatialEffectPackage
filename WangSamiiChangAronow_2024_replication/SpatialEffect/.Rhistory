exp_data1 <- exp_data1[complete.cases(exp_data1[, c(dem_outcome, covs_names)]), c(dem_outcome, covs_names, "control", "priming")]
exp_data2 <- exp_data[exp_data$control == 1 | exp_data$economic == 1, ]
exp_data2 <- exp_data2[complete.cases(exp_data2[, c(dem_outcome, covs_names)]), c(dem_outcome, covs_names, "control", "economic")]
exp_data3 <- exp_data[exp_data$control == 1 | exp_data$political == 1, ]
exp_data3 <- exp_data3[complete.cases(exp_data3[, c(dem_outcome, covs_names)]), c(dem_outcome, covs_names, "control", "political")]
reg01 <- lm_lin(as.formula(paste0(dem_outcome, "~priming")), as.formula(paste0("~", paste0(covs_names, collapse = "+"))), exp_data1)
reg02 <- lm_lin(as.formula(paste0(dem_outcome, "~economic")), as.formula(paste0("~", paste0(covs_names, collapse = "+"))), exp_data2)
reg03 <- lm_lin(as.formula(paste0(dem_outcome, "~political")), as.formula(paste0("~", paste0(covs_names, collapse = "+"))), exp_data3)
dem_coefs_data[1, c(1, 2)] <- round(summary(reg01)$coefficients[5, c(1:2)], 4)
dem_coefs_data[2, c(1, 2)] <- round(summary(reg01)$coefficients[6, c(1:2)], 4)
dem_coefs_data[3, c(1, 2)] <- round(summary(reg02)$coefficients[5, c(1:2)], 4)
dem_coefs_data[4, c(1, 2)] <- round(summary(reg02)$coefficients[6, c(1:2)], 4)
dem_coefs_data[5, c(1, 2)] <- round(summary(reg03)$coefficients[5, c(1:2)], 4)
dem_coefs_data[6, c(1, 2)] <- round(summary(reg03)$coefficients[6, c(1:2)], 4)
dem_coefs_data[, 3] <- dem_coefs_data[, 1] - 1.96*dem_coefs_data[, 2]
dem_coefs_data[, 4] <- dem_coefs_data[, 1] + 1.96*dem_coefs_data[, 2]
dem_coefs_data <- as.data.frame(dem_coefs_data)
names(dem_coefs_data) <- c("est", "se", "CI95_upper", "CI95_lower")
dem_coefs_data$names <- c("Priming * Pro-market", "Priming * Pro-regime", "Economic * Pro-market", "Economic * Pro-regime", "Political * Pro-market", "Political * Pro-regime")
dem_coefs_data$names <- factor(dem_coefs_data$names, levels = rev(rev(dem_coefs_data$names)))
dem_plot <- ggplot(dem_coefs_data) +
geom_pointrange(aes(x=names, y=est, ymin=CI95_lower, ymax=CI95_upper), size = 0.3) +
theme_bw() + geom_hline(aes(yintercept = 0), colour = "black", lty=2) + xlab('') + ylab('') + ggtitle(paste0("Effect Estimates for ", dem_outcome)) +
theme(plot.title = element_text(hjust = 0.5), text = element_text(size=12), axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1), legend.position = "none")
ggsave(paste0("../graphs/pilot/dem/hte_est_", dem_outcome, ".pdf"), dem_plot)
}
